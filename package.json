{
  "name": "sshelf",
  "version": "0.5.6",
  "description": "A local-first, Notion-style desktop workspace for the files on a remote SSH machine",
  "author": "Pierre-Loic Deschaetzen",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pldesch/sshelf.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite dev --port 3010",
    "electron:dev": "concurrently -k \"vite dev --port 3010\" \"wait-on http://localhost:3010 && electron .\"",
    "build": "vite build",
    "electron:pack": "bun run build && electron-builder --dir",
    "electron:pack:mac": "bun run build && electron-builder --mac --arm64 --x64 --dir",
    "electron:pack:win": "bun run build && electron-builder --win --x64 --dir",
    "electron:build": "bun run build && electron-builder",
    "electron:dist:mac": "bun run build && electron-builder --mac --arm64 --x64",
    "electron:dist:win": "bun run build && electron-builder --win --x64",
    "release": "bun run build && electron-builder --publish always",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "check": "prettier --check \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "jsdom": "^28",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "@noble/hashes": "1.8.0"
  },
  "build": {
    "appId": "com.sshelf.app",
    "productName": "Sshelf",
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "afterPack": "build/afterPack.cjs",
    "publish": {
      "provider": "github",
      "owner": "Pldesch",
      "repo": "sshelf",
      "releaseType": "release"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
